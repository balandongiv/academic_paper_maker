@ARTICLE{Vishwakarma2026,
	author = {Vishwakarma, Sanjay and Narayanan, Naveen and Harsha, Suraj Prakash and Sharma, Satish Chandra},
	title = {Fatigue crack growth analysis of Improved Switch Expansion Joints under cyclic Loading: A parametric study on crack size and orientation},
	year = {2026},
	journal = {Engineering Failure Analysis},
	volume = {185},
	pages = {},
	doi = {10.1016/j.engfailanal.2025.110359},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105022839584&doi=10.1016%2Fj.engfailanal.2025.110359&partnerID=40&md5=ec9e924aa9dd4f857f3dcc201a47d60c},
	affiliations = {Indian Institute of Technology Roorkee, Department of Mechanical and Industrial Engineering, Roorkee, UK, India},
	abstract = {Fatigue crack growth in railway track components remains a critical challenge to maintaining long-term safety and structural integrity, particularly in Improved Switch Expansion Joints (ISEJs), where complex load-transfer mechanisms and stress concentrations accelerate damage initiation and progression. This study ware aims to evaluate the influence of crack orientation and size on fatigue crack propagation in ISEJs under cyclic wheel loading. A three-dimensional finite element (FE) model incorporating the ISEJ track components was developed to compute Mode I Stress Intensity Factors (K<inf>1</inf>) for cracks initiating at rail corners. Parametric analyses revealed that K<inf>1</inf> increased with crack depth, confirming the direct correlation between crack size and fracture driving force. The frictional contact region of ISEJ exhibited up to 12 % higher K<inf>1</inf> values compared to the bolted region due to elevated tangential stresses. Vertical cracks (0° orientation) showed the most critical behaviour, with crack extensions of approximately 26 mm at 4 × 10<sup>5</sup> and 7 × 10<sup>5</sup> loading cycles in the frictional and bolted regions, respectively. Among inclined cracks, 30° orientations demonstrated up to 15 % higher propagation rates depending on local geometry. These findings highlight that fatigue performance in ISEJs is governed by both crack orientation and contact mechanics, emphasizing the need for targeted inspection strategies and design refinements to mitigate stress concentrations and extend service life. © 2025},
	author_keywords = {Crack Orientation; Crack Propagation; Fatigue Crack Growth; Finite Element Method; Improved Switch Expansion Joint; Stress Intensity Factor},
	keywords = {Bolts; Cyclic loads; Expansion; Fatigue crack; Fatigue damage; Friction; Loading; Rail laying; Railroad tracks; Railroad transportation; Railroads; Stress analysis; Stress concentration; Crack orientations; Crack sizes; Cracks propagation; Element method; Fatigue crack growth analysis; Fatigue cracks; Improved switch expansion joint; Parametric study; Stress-intensity factors; Track components; Fatigue crack propagation; Stress intensity factors},
	correspondence_address = {S.P. Harsha; Centre for Railway Research (CRR), Advanced Mechanical Vibration Lab, Mechanical & Industrial Engineering Department, IIT Roorkee, India; email: spharsha@me.iitr.ac.in},
	publisher = {Elsevier Ltd},
	issn = {13506307},
	coden = {EFANE},
	language = {English},
