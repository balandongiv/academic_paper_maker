	title = {Insight into the corrosion fatigue crack growth mechanism of a Zr-Sn-Nb alloy in simulated PWR primary water},
	year = {2026},
	journal = {Corrosion Science},
	volume = {262},
	pages = {},
	doi = {10.1016/j.corsci.2026.113668},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105028700615&doi=10.1016%2Fj.corsci.2026.113668&partnerID=40&md5=d9ebff82678a55e18e14956b88221337},
	affiliations = {Nuclear Power Institute of China, Beijing, China},
	abstract = {The corrosion fatigue crack growth (CFCG) behavior of a Zr–Sn–Nb alloy was systematically investigated in simulated PWR primary water (320 °C, 12.5 MPa) under controlled dissolved oxygen (DO: 10–500 ppb) and dissolved hydrogen (DH: 0–30 cc (STP)/kg H₂O) conditions. A pronounced environmental acceleration is demonstrated, with the CFCG rate under low frequency (0.001 Hz), high stress ratio (0.9), and 100 ppb DO exceeding the air value by up to a factor of 250. In contrast, DO and DH variations exhibit only a modest influence on crack growth kinetics within the tested ranges. Microstructural analyses reveal a crack-tip oxide scale predominantly composed of monoclinic ZrO₂, accompanied by limited dislocation activity and extensive needle-shaped hydride precipitation in the adjacent matrix. The observed behavior is consistent with a slip-oxidation-rupture mechanism, which is established as the governing process. These findings underscore that mechanical driving forces (frequency, stress ratio), rather than bulk water redox chemistry, dominate the CFCG response of zirconium alloys in this environment. © 2026},
	author_keywords = {Corrosion fatigue crack growth; Simulated PWR primary water; Zr–Sn–Nb alloy},
	keywords = {Corrosion; Crack tips; Dissolved oxygen; Fatigue crack propagation; Growth kinetics; Precipitation (chemical); Scale (deposits); Tin alloys; Zirconium alloys; Condition; Corrosion fatigue crack growth; Corrosion-fatigue; Dissolved hydrogen; Fatigue crack growth behavior; Fatigue crack growth mechanism; Fatigue cracks; PWR primary waters; Simulated PWR primary water; Zr-Sn-Nb alloy; Corrosion fatigue},
