	doi = {10.1016/j.engfracmech.2026.111943},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105030296351&doi=10.1016%2Fj.engfracmech.2026.111943&partnerID=40&md5=efb39c0435bc5d0009207adee9a0e817},
	affiliations = {Chongqing University, Chongqing, China; Chongqing University, School of Resources and Safety Engineering, Chongqing, China; Sinopec, Beijing, China},
	abstract = {Compared to conventional hydraulic fracturing (CHF), pulsed hydraulic fracturing (PHF) demonstrates greater advantages in reducing fracture initiation pressure, facilitating layer penetration, and creating complex fracture networks in coal measure strata (CMS). In this paper, the hydraulic fractures propagation behavior under different combination modes are investigated via triaxial PHF system experiments. The results show that, compared to CHF, PHF significantly reduces the initiation pressure by 8.80% −31.85%, the transient initiation energy by 12.83% − 52.52%, while the cumulative AE energy under dispersed release of energy is increased by 0.85––2.67 times. In addition, both the transient initiation pressure and initiation energy exhibited a negative exponential decrease trend as the pulse amplitude increases. Assisted by computed tomography (CT) scans, the increases in stimulated reservoir volume (SRV) and vertical fracture height coefficient (VFH) confirm that PHF can effectively promote cross-layer fracture propagation and generate a complex fracture network. Based on the calculation of type I stress intensity factor, the fractures tend to penetrate from high-elastic-modulus rock to low-elastic-modulus rock, and PHF could assist in driving fractures through layers from low-elastic-modulus to high-elastic-modulus rocks. This is highly related to the enhanced stress concentration effect on fracture tips and fatigue damage effect under cyclic pulsed loading during PHF. Moreover, pressure relief becomes more pronounced with pulse amplitude increasing, which enhances cross-layer effect. However, higher pulse amplitude can significantly enhance cross-layer effect, while weakening the fracture complexity to some extent. This study can provide a theoretical basis for fracturing formation selection and pulse parameter design. © © 2026. Published by Elsevier Ltd.},
	author_keywords = {Coal measurestrata; Cross-layer propagation; Pressure relief; Pulsed hydraulic fracturing},
	keywords = {Complex networks; Computerized tomography; Crack propagation; Fatigue damage; Fracture; Hydraulic fracturing; Network layers; Petroleum reservoir evaluation; Pressure effects; Stress analysis; Stress intensity factors; Coal measure stratum; Coal measurestratum; Cross layer; Cross-layer propagation; Fracture network; Initiation energy; Pressure relief; Propagation behavior; Pulse amplitude; Pulsed hydraulic fracturing; Elastic moduli},
	correspondence_address = {C. Xiao; State Key Laboratory of Coal Mine Disaster Dynamics and Control, Chongqing University, Chongqing, 400044, China; email: xiaocy@cqu.edu.cn},
	publisher = {Elsevier Ltd},
	issn = {00137944},
	isbn = {0080316573},
	coden = {EFMEA},
	language = {English},
	abbrev_source_title = {Eng. Fract. Mech.},
