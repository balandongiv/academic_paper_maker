@ARTICLE{Hu2026,
	author = {Hu, Zhizheng and Kui, Hailin and Jiang, Zhende and Wang, Chun and Liu, Xiangyu},
	title = {Robust monitoring of tractor driver fatigue state based on adversarial training of working conditions and multi-level adaptive information fusion},
	year = {2026},
	journal = {Computers and Electronics in Agriculture},
	volume = {243},
	pages = {},
	doi = {10.1016/j.compag.2026.111422},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105028711237&doi=10.1016%2Fj.compag.2026.111422&partnerID=40&md5=b2e4db1c6dbf04d12189155adc431822},
	affiliations = {Jilin University, College of Biological and Agricultural Engineering, Changchun, Jilin, China; The Second Hospital of Jilin University, Orthopaedic Medical Center, Changchun, Jilin, China; Jilin University, Changchun, Jilin, China},
	abstract = {Monitoring the fatigue state of tractor drivers by fusing multimodal signals—including electroencephalography (EEG), electrocardiography (ECG), and eye-tracking metrics (EM)—is critical for ensuring safety in agricultural production. However, under real-world farming conditions, varying task loads (e.g., plowing, seeding) induce physiological responses that are highly similar to those of genuine fatigue, creating strongly correlated structured noise. Existing decoding algorithms tend to overlook this confounding effect, resulting in insufficient robustness and limited performance in dynamic operational scenarios. To this end, we propose a Condition-Aware Adaptive Fusion Network (CAAF-Net), designed to decouple the feature representations of task load and true fatigue at their source. The network incorporates two primary innovations. First, an Adversarial Feature Decoupling module, driven by a Gradient Reversal Layer (GRL), compels the model to learn task-invariant and pure fatigue representations. Second, an ’Interact-then-Weight’ Cascaded Fusion strategy first employs a cross-attention-based module to align and enhance inter-modal features, then subsequently utilizes a dynamic performance-guided module to assign adaptive fusion weights based on the information entropy of each modality. To validate our approach, we established a simulated driving experiment encompassing three typical agricultural tasks and collected a novel trimodal physiological and behavioral dataset (EEG, ECG, EM; 8 subjects). Experimental results demonstrate that CAAF-Net achieves a fatigue recognition accuracy of 95.8 %, significantly outperforming existing methods. In-depth ablation studies and visualization analyses further corroborate the efficacy of the proposed modules in enhancing model robustness and fusion efficiency. CAAF-Net offers a novel and effective paradigm for separating structured noise from multimodal signals in complex scenarios, holding significant value for the development of highly robust driver state monitoring systems. © 2026 Elsevier B.V.},
	author_keywords = {Domain-adversarial training; Driver fatigue; Multimodal fusion; Riemannian manifold},
	keywords = {Agriculture; Biomedical signal processing; Electrocardiography; Electrophysiology; Fatigue of materials; Information fusion; Physiological models; Tractors (agricultural); Tractors (truck); Adaptive fusion; Condition; Domain-adversarial training; Driver fatigue; Eye-tracking; Multi-modal; Multi-modal fusion; Riemannian manifold; Robust monitoring; Structured noise; Electroencephalography; detection method; experimental study; safety; training; visualization; working conditions},
	correspondence_address = {X. Liu; College of Biological and Agricultural Engineering, Jilin University, Changchun, Jilin, China; email: liuxy91@jlu.edu.cn},
	publisher = {Elsevier B.V.},
	issn = {01681699},
	coden = {CEAGE},
	language = {English},
	abbrev_source_title = {Comput. Electron. Agric.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{AlHousrya2026,
	author = {AlHousrya, Obaida and Bennagi, Aseel and Cotfas, Petru Adrian and Cotfas, Daniel Tudor},
