	title = {Effect of oxygen on fatigue crack growth in P92 steel at 600 °C: Atmosphere and vacuum},
	year = {2026},
	journal = {Corrosion Science},
	volume = {262},
	pages = {},
	doi = {10.1016/j.corsci.2026.113680},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105028969515&doi=10.1016%2Fj.corsci.2026.113680&partnerID=40&md5=2ec772a45a9dc37fe04a693664400745},
	affiliations = {East China University of Science and Technology, Key Laboratory of Pressure Systems and Safety, Shanghai, China; City University of Hong Kong, Department of Mechanical Engineering, Hong Kong, Hong Kong; Shanghai Institute of Aircraft Mechanics and Control, Shanghai, China; Longyan University, College of Physics and Electromechanics, Longyan, Fujian, China},
	abstract = {Oxidation plays a critical role in the fatigue failure of high-temperature alloys, yet its synergy with creep during fatigue crack growth (FCG) remains insufficiently resolved. Here, FCG behavior of P92 steel at 600 °C was quantified under high vacuum (∼10<sup>−3</sup> Pa) and atmosphere using trapezoidal loading with varying hold times (0–3600 s), to isolate coupled oxidation-creep effects. Relative to vacuum, oxidation in atmosphere accelerated FCG: to reach a 1 mm crack extension, atmosphere required 1585 cycles versus 3051 in vacuum (51.9 % of the cycles). The acceleration intensified with extended holding: at ΔK = 38.4 MPa·m<sup>0.5</sup> with a hold time of 3600 s, the atmospheric da/dN was approximately 4.28 times the vacuum value. A ΔK-dependent transition was identified: oxidation elevated da/dN below approximately 35–40 MPa·m<sup>0.5</sup>, whereas rates in atmosphere and vacuum converged at higher ΔK (dominated by mechanical driving force). Mechanistically, atmosphere promoted fatigue-dominated transgranular cracking via cyclic crack-tip oxide fracture/reformation, whereas longer hold time in vacuum shift the path from transgranular to mixed trans/intergranular with creep cavity nucleation along boundaries. Oxide analysis showed a stratified scale with an Fe-rich outer layer and a Cr-enriched inner layer adjacent to the substrate, consistent with outward Cr diffusion. The proposed failure mechanism maps offered insights into the interaction between oxidation, creep, and fatigue, providing a framework for understanding FCG of P92 under service conditions. © 2026 Elsevier Ltd},
	author_keywords = {Atmosphere; Creep; Damage mechanism; Fatigue; Oxidation; P92 steel; Vacuum},
	keywords = {Crack tips; Earth atmosphere; Fatigue crack; Fatigue crack propagation; Fatigue damage; Oxygen; Thermal fatigue; Damage mechanism; Effect of oxygen; Fatigue crack growth behavior; Fatigue cracks; Fatigue failures; High vacuum; Highest temperature; Hold time; In-vacuum; P92 steels; Creep; Oxidation},
	correspondence_address = {J.-F. Wen; Key Laboratory of Pressurized System and Safety, Ministry of Education, East China University of Science and Technology, Shanghai, 200237, China; email: jfwen@ecust.edu.cn},
	publisher = {Elsevier Ltd},
